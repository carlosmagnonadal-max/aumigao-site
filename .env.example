# Chatbot Au — Anthropic
ANTHROPIC_API_KEY=

# Rate limit global (Upstash Redis REST) — opcional, mas recomendado em produção.
# Sem essas envs, o rate-limit cai em modo in-memory (por instância, não cross-instância).
# Configure em: https://console.upstash.com → Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
